{
	"name": "backend",
	"module": "server.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun --hot src/server.ts",
		"start": "bun src/server.ts",
		"db:migrate": "bunx prisma migrate deploy --schema src/database/prisma/schema.prisma",
		"db:reset": "bunx prisma migrate reset --force --schema src/database/prisma/schema.prisma",
		"start:prod": "bun src/scripts/start.ts --migrate=deploy",
		"start:skip-migrate": "bun src/scripts/start.ts --migrate=skip",
		"start:reset": "bun src/scripts/start.ts --migrate=reset",
		"test": "NODE_ENV=test vitest run",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"devDependencies": {
		"@types/bcrypt": "^6.0.0",
		"@types/bun": "^1.3.14",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/nodemailer": "^7.0.0",
		"@types/node": "^26.0.1",
		"biome": "^0.3.3",
		"tsx": "^4.22.4",
		"vitest": "^4.1.9"
	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1086.0",
		"@fastify/cookie": "^11.0.2",
		"@fastify/cors": "^11.2.0",
		"@fastify/helmet": "^13.0.2",
		"@fastify/jwt": "^10.1.0",
		"@fastify/multipart": "^10.0.0",
		"@fastify/oauth2": "^8.2.0",
		"@fastify/rate-limit": "^11.0.0",
		"@fastify/swagger": "^9.7.0",
		"@fastify/swagger-ui": "^6.0.0",
		"@fastify/type-provider-typebox": "^6.1.0",
		"@fastify/websocket": "^11.2.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@sinclair/typebox": "^0.34.49",
		"@zrosenbauer/fastify-prisma": "^7.0.2",
		"bcrypt": "^6.0.0",
		"bullmq": "^5.79.1",
		"dotenv": "^17.4.2",
		"fastify": "^5.8.5",
		"fastify-plugin": "^6.0.0",
		"fastify-type-provider-zod": "^7.0.0",
		"ioredis": "^5.11.1",
		"jsonwebtoken": "^9.0.3",
		"nodemailer": "^7.0.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"prisma": "^7.8.0",
		"sharp": "^0.35.3",
		"uuid": "^14.0.1",
		"zod": "^4.4.3"
	}
}
