{
	"name": "nalumv2",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.11",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"infra": "bun index.ts",
		"module": "bun scripts/utils/create-module.ts",
